{
  "name": "pirate-search",
  "version": "1.1.0",
  "description": "Search The Pirate Bay (via apibay.org), browse Top 100, and send torrents straight to qBittorrent",
  "author": "Andy Freed",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node make-icon.js",
    "dist": "node make-icon.js && electron-builder --win nsis",
    "release": "node make-icon.js && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.andyfreed.piratesearch",
    "productName": "Pirate Search",
    "directories": {
      "output": "installer",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "andyfreed",
        "repo": "pirate-search",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pirate Search",
      "uninstallDisplayName": "Pirate Search",
      "artifactName": "${productName} Setup ${version}.${ext}"
    }
  }
}
